create or replace view default.dim_shop_details
  
  
  as
    -- Create a temporary view with 100 rows using range



WITH shop_data AS (
  SELECT
    id + 1 AS shop_id,
    CONCAT('Shop ', LPAD(CAST(id + 1 AS STRING), 3, '0')) AS shop_name,
    CONCAT('Owner_', CAST(SHA1(RAND(id)) AS STRING)) AS owner_name,
    CASE
      WHEN id % 5 = 0 THEN 'New York'
      WHEN id % 5 = 1 THEN 'Los Angeles'
      WHEN id % 5 = 2 THEN 'Chicago'
      WHEN id % 5 = 3 THEN 'Houston'
      ELSE 'Phoenix'
    END AS city,
    DATE_SUB(CURRENT_DATE(), CAST(RAND(id) * 365 AS INT)) AS created_at
  FROM range(100)
)
SELECT * FROM shop_data;

